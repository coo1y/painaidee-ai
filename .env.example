# --- OpenAI (required for CLI ingest + eval with real embeddings/chat) ---
OPENAI_API_KEY=XXXXXX
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Tavily web search (optional; for CLI smoke tests of web search) ---
TAVILY_API_KEY=XXXXXX

# --- Embedding backend: "openai" (default) or "local" (deterministic, offline test only) ---
EMBEDDING_BACKEND=openai

# --- Paths (defaults are fine for local + docker) ---
CHROMA_DIR=./chroma_db
FEEDBACK_DB=./feedback.db
DATA_DIR=./data
