# Copy this file to `.env` and fill in your real keys.
# NEVER commit the real .env file.

# --- OpenAI (required for real embeddings + chat) ---
OPENAI_API_KEY=XXXXXX
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Tavily web search (optional; web-search tool is skipped if empty) ---
TAVILY_API_KEY=XXXXXX

# --- Embedding backend: "openai" (default) or "local" (deterministic, offline test only) ---
EMBEDDING_BACKEND=openai

# --- Paths (defaults are fine for local + docker) ---
CHROMA_DIR=./chroma_db
FEEDBACK_DB=./feedback.db
DATA_DIR=./data
